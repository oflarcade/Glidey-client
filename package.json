{
  "name": "rentascooter-client",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "android:clean": "expo prebuild --clean && expo run:android",
    "build": "eas build",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "lint": "eslint .",
    "clean": "rm -rf .expo ios android node_modules"
  },
  "dependencies": {
    "@expo-google-fonts/roboto": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-native/normalize-colors": "^0.81.5",
    "@rentascooter/api": "file:./packages/api",
    "@rentascooter/auth": "file:./packages/auth",
    "@rentascooter/i18n": "file:./packages/i18n",
    "@rentascooter/onboarding": "file:./packages/onboarding",
    "@rentascooter/shared": "file:./packages/shared",
    "@rentascooter/ui": "file:./packages/ui",
    "@rnmapbox/maps": "^10.2.10",
    "@tanstack/react-query": "^5.90.18",
    "expo": "~54.0.31",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.0",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.0",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.0",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "firebase": "^11.3.0",
    "i18n-js": "^4.4.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "4.1.6",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.3.3",
    "uuid": "^11.0.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "react-native-svg-transformer": "^1.5.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
