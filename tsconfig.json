{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@rentascooter/shared": ["./packages/shared/src"],
      "@rentascooter/shared/*": ["./packages/shared/src/*"],
      "@rentascooter/auth": ["./packages/auth/src"],
      "@rentascooter/auth/*": ["./packages/auth/src/*"],
      "@rentascooter/onboarding": ["./packages/onboarding/src"],
      "@rentascooter/onboarding/*": ["./packages/onboarding/src/*"],
      "@rentascooter/ui": ["./packages/ui/src"],
      "@rentascooter/ui/*": ["./packages/ui/src/*"],
      "@rentascooter/i18n": ["./packages/i18n/src"],
      "@rentascooter/i18n/*": ["./packages/i18n/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx"
  ]
}
